model User {
  id Int @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  password String

  roleId Int
  role   Role   @relation(fields: [roleId], references: [id])

  bookings Booking[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([roleId])
}

model Role {
  id Int @id @default(autoincrement())
  name String @unique

  users User[]
   permissions RolePermission[]   // 🔥 ADD THIS
}

model Permission {
  id   Int @id @default(autoincrement())
  key  String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model CarCategory {
  id Int @id @default(autoincrement())
  name     String
  capacity Int

  cars     Car[]
  bookings Booking[]
  manualPricing ManualPricing[]
  packageEnquiries PackageEnquiry[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Car {
  id Int @id @default(autoincrement())
  model       String
  plateNumber String @unique

  categoryId Int
  category   CarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  driver Driver?
  bookings Booking[]

  @@index([categoryId])
}

model Driver {
  id Int @id @default(autoincrement())
  name  String
  phone String

  carId Int @unique
  car   Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  status String @default("offline")

  bookings Booking[]
}

model Booking {
  id Int @id @default(autoincrement())
  bookingNumber String  @unique

  userId        Int
  carCategoryId Int
  driverId      Int?
  carId         Int?

  guestName     String?
  gender        String?
  email         String?
  mobileNumber  String
  corporateName String?

  pickupAddress String
  dropAddress   String
  exactPickupAddress String?
  exactDropAddress   String?

  status        String @default("new_booking")
  hub           String?
  allotedTo     String?
  carDispatched Boolean @default(false)

  fare        Float?
  grandTotal  Float?
  totalKm     Float @default(0)
  costPerKm   Float @default(0)
  extraKmCost Float @default(0)
  tollsCost   Float @default(0)

  scheduledAt DateTime?
  pickupTime  String?
  paymentStatus String @default("pending")
  tytRate       Float?
  multiplyBy    Float @default(1)
  createdAt   DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  carCategory CarCategory @relation(fields: [carCategoryId], references: [id])
  driver      Driver?     @relation(fields: [driverId], references: [id])
  car         Car?        @relation(fields: [carId], references: [id])

  payments Payment[]
  logs     BookingLog[]

  @@index([userId])
  @@index([driverId])
  @@index([bookingNumber])
}

model Payment {
  id Int @id @default(autoincrement())
  bookingId Int
  amount    Float
  status    String
  provider  String
  transactionId String?

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PackageCategory {
  id Int @id @default(autoincrement())
  name String

  isActive  Boolean @default(true)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  packages Package[]
}

model Package {
  id Int @id @default(autoincrement())
  title    String
  images   Json
  price    Float
  carPrices Json?
  duration String
  features Json

  tag      String?
  isActive Boolean @default(true)

  categoryId Int?
  category   PackageCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  enquiries PackageEnquiry[]
}

model PackageEnquiry {
  id Int @id @default(autoincrement())
  name      String
  email     String?
  phone     String
  fromDate  DateTime
  toDate    DateTime
  message   String? @db.Text
  packageId Int
  carCategoryId Int?

  status    String @default("pending")
  createdAt DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)
  carCategory CarCategory? @relation(fields: [carCategoryId], references: [id])
}

model ManualPricing {
  id Int @id @default(autoincrement())
  categoryId Int
  from   String
  to     String
  date   DateTime
  price  Float

  category CarCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, from, to, date])
}

model Stock {
  id Int @id @default(autoincrement())
  from      String
  car       String
  price     Float
  trend     String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([from, car])
}

model BookingLog {
  id Int @id @default(autoincrement())
  bookingId Int
  action    String
  message   String

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

