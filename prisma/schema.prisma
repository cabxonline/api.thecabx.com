generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String?
  password String

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  offerRedemptions OfferRedemption[]

  bookings Booking[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  users       User[]
  permissions RolePermission[]

  createdAt DateTime @default(now())
}

model Permission {
  id   String @id @default(uuid())
  key  String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model MailTemplate {
  id        String   @id @default(uuid())
  key       String   @unique
  name      String
  subject   String
  body      String
  isActive  Boolean  @default(true)
}

model City {
  id        String   @id @default(uuid())
  name      String
  state     String
  image     String   // ✅ ADD THIS
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
model CarCategory {
  id       String @id @default(uuid())
  name     String
  capacity Int
  baseFare Float
  perKm    Float

  cars     Car[]
  bookings Booking[]

  manualPricing ManualPricing[]   // ✅ ADD THIS

  createdAt DateTime @default(now())
}

model Car {
  id          String @id @default(uuid())
  model       String
  plateNumber String @unique

  categoryId String
  category   CarCategory @relation(fields: [categoryId], references: [id])

  driver Driver?
}

model Driver {
  id    String @id @default(uuid())
  name  String
  phone String

  carId String @unique
  car   Car    @relation(fields: [carId], references: [id])

  lat    Float?
  lng    Float?
  status String @default("offline")

  bookings Booking[]
}

model Booking {
  id            String  @id @default(uuid())
  userId        String
  carCategoryId String
  driverId      String?

  pickupAddress String
  dropAddress   String

  status String @default("pending")
  fare   Float?

  scheduledAt DateTime?
  createdAt   DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id])
  carCategory CarCategory @relation(fields: [carCategoryId], references: [id])
  driver      Driver?     @relation(fields: [driverId], references: [id])

  trip     Trip?
  payments Payment[]
  logs     BookingLog[] // ✅ ADD THIS

  @@index([userId])
  @@index([driverId])
}

model Trip {
  id        String @id @default(uuid())
  bookingId String @unique

  startTime DateTime?
  endTime   DateTime?

  booking Booking @relation(fields: [bookingId], references: [id])
}

model Payment {
  id        String @id @default(uuid())
  bookingId String
  amount    Float
  status    String
  provider  String

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
}

model Offer {
  id          String  @id @default(uuid())
  title       String
  description String?
  code        String  @unique
  discount    Float

  type        String // "flat" or "percent"
  maxDiscount Float?

  minAmount Float? // minimum booking value

  usageLimit Int? // total usage limit
  usedCount  Int  @default(0)

  isActive Boolean @default(true)

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  redemptions OfferRedemption[]
}

model OfferRedemption {
  id String @id @default(uuid())

  offerId String
  userId  String

  usedAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([offerId, userId]) // one user = one use
}

model PackageCategory {
  id        String   @id @default(uuid())
  name      String
  image     String?        // category banner/icon
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages  Package[]
}

model Package {
  id          String   @id @default(uuid())
  title       String
  images      String[]     // multiple images (IMPORTANT)
  price       Float
  duration    String
  features    String[]
  tag         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  String?
  category    PackageCategory? @relation(fields: [categoryId], references: [id])
  enquiries   PackageEnquiry[]
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  blogs     Blog[]

  createdAt DateTime @default(now())
}

model Blog {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String
  content     String
  image       String?

  categoryId  String
  category    BlogCategory @relation(fields: [categoryId], references: [id])

  isPublished Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ManualPricing {
  id        String   @id @default(uuid())

  carId     String
  from      String
  to        String

  date      DateTime @db.Date   // 🔥 only date, no time issue
  price     Float

  tripType  String?             // optional (oneway / round)

  car       CarCategory @relation(fields: [carId], references: [id])

  createdAt DateTime @default(now())

  @@unique([carId, from, to, date])   // ❌ no duplicate pricing
  @@index([carId, from, to, date])    // ⚡ fast query
}

model stock {
  id        String   @id @default(uuid())
  from      String
  to        String
  car       String
  price     Float
  trend     Trend
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Trend {
  UP
  DOWN
}

model PackageEnquiry {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String
  fromDate  String
  toDate    String
  message   String?
  
  packageId String
  package   Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  status    String   @default("pending") // pending, contacted, resolved
  createdAt DateTime @default(now())
}

model BookingLog {
  id        String   @id @default(uuid())
  bookingId String
  action    String   // e.g. "DISPATCH", "REASSIGN", "PAYMENT_CASH"
  message   String
  createdAt DateTime @default(now())

  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}