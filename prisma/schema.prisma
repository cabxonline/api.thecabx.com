generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id Int @id @default(autoincrement())
  name     String
  email    String  @unique
  phone    String?
  password String

  roleId Int
  role   Role   @relation(fields: [roleId], references: [id])

  bookings Booking[]
  notifications Notification[]
  supportTickets SupportTicket[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([roleId])
}

model Role {
  id Int @id @default(autoincrement())
  name String @unique

  users User[]
   permissions RolePermission[]   // 🔥 ADD THIS
}

model Permission {
  id   Int @id @default(autoincrement())
  key  String @unique
  name String

  roles RolePermission[]
}

model RolePermission {
  id Int @id @default(autoincrement())

  roleId       Int
  permissionId Int

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model CarCategory {
  id Int @id @default(autoincrement())
  name     String
  capacity Int

  cars     Car[]
  bookings Booking[]
  manualPricing ManualPricing[]
  packageEnquiries PackageEnquiry[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Car {
  id Int @id @default(autoincrement())
  model       String
  plateNumber String @unique

  categoryId Int
  category   CarCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  driver Driver?
  bookings Booking[]

  @@index([categoryId])
}

model Driver {
  id Int @id @default(autoincrement())
  name  String
  phone String

  carId Int @unique
  car   Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  status String @default("offline")

  bookings Booking[]
}

model Booking {
  id Int @id @default(autoincrement())
  bookingNumber String  @unique

  userId        Int
  carCategoryId Int
  driverId      Int?
  carId         Int?

  guestName     String?
  gender        String?
  email         String?
  mobileNumber  String
  corporateName String?

  pickupAddress String
  dropAddress   String
  exactPickupAddress String?
  exactDropAddress   String?

  status        String @default("new_booking")
  hub           String?
  allotedTo     String?
  carDispatched Boolean @default(false)

  fare        Float?
  grandTotal  Float?
  totalKm     Float @default(0)
  costPerKm   Float @default(0)
  extraKmCost Float @default(0)
  tollsCost   Float @default(0)

  scheduledAt DateTime?
  pickupTime  String?
  paymentStatus String @default("pending")
  tytRate       Float?
  multiplyBy    Float @default(1)
  createdAt   DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  carCategory CarCategory @relation(fields: [carCategoryId], references: [id])
  driver      Driver?     @relation(fields: [driverId], references: [id])
  car         Car?        @relation(fields: [carId], references: [id])

  payments Payment[]
  logs     BookingLog[]

  couponId Int?
  coupon   Coupon?     @relation(fields: [couponId], references: [id])
  discountAmount Float? @default(0)

  packageId   Int?
  package     Package?    @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([driverId])
  @@index([bookingNumber])
}

model Payment {
  id Int @id @default(autoincrement())
  bookingId Int
  amount    Float
  status    String
  provider  String
  transactionId String?
  type          String   @default("payment") // "payment", "refund"
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model PackageCategory {
  id   Int    @id @default(autoincrement())
  name String
  description String? @db.Text

  isActive  Boolean @default(true)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  packages Package[]
}

model Package {
  id Int @id @default(autoincrement())
  title    String
  images   Json
  price    Float
  carPrices Json?
  duration String
  features Json

  tag      String?
  isActive Boolean @default(true)

  categoryId Int?
  category   PackageCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  enquiries PackageEnquiry[]
  bookings  Booking[]
}

model PackageEnquiry {
  id Int @id @default(autoincrement())
  name      String
  email     String?
  phone     String
  fromDate  DateTime
  toDate    DateTime
  message   String? @db.Text
  packageId Int?
  stockId   Int?
  carCategoryId Int?

  status    String @default("pending")
  createdAt DateTime @default(now())

  package Package? @relation(fields: [packageId], references: [id], onDelete: Cascade)
  stock   Stock?   @relation(fields: [stockId], references: [id])
  carCategory CarCategory? @relation(fields: [carCategoryId], references: [id])
}

model ManualPricing {
  id Int @id @default(autoincrement())
  categoryId Int
  from   String
  to     String
  date   DateTime
  price  Float

  category CarCategory @relation(fields: [categoryId], references: [id])

  @@unique([categoryId, from, to, date])
}

model Stock {
  id Int @id @default(autoincrement())
  from      String
  car       String
  price     Float
  trend     String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  enquiries PackageEnquiry[]

  @@unique([from, car])
}

model BookingLog {
  id Int @id @default(autoincrement())
  bookingId Int
  action    String
  message   String

  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model MailTemplate {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  name         String
  subject      String
  from_address String?
  from_name    String?
  body_html    String?  @db.Text
  body_text    String?  @db.Text
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now()) @updatedAt
}

model Coupon {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  title           String
  description     String?
  termsConditions String?   @db.Text
  discountType    String    // "percentage" or "fixed"
  discountValue   Float
  maxDiscount     Float?
  minOrderValue   Float?

  targetCity      String?
  tripType        String?
  applicableOn    String    @default("both") // "booking", "package", "both"
  targetRideCounts String?

  startDate       DateTime?
  endDate         DateTime?
  isActive        Boolean   @default(true)
  maxUsagePerUser Int?      @default(1)
  totalUsageLimit Int?
  usedCount       Int       @default(0)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  bookings        Booking[]
}

model TytTrend {
  id        Int      @id @default(autoincrement())
  tripType  String   @unique // "roundtrip", "local", "airport"
  config    Json     // stores day-by-day trend configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookingId Int?
  type      String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
model Policy {
  id        Int      @id @default(autoincrement())
  key       String   @unique // "privacy-policy", "terms-and-condition", "refund-policy"
  title     String
  content   String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt
}

model SupportTicket {
  id          Int            @id @default(autoincrement())
  ticketId    String         @unique // ST-XXXXXX
  userId      Int
  subject     String
  status      String         @default("open") // "open", "in_progress", "closed"
  priority    String         @default("medium") // "low", "medium", "high"
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies     SupportReply[]

  @@index([userId])
  @@index([ticketId])
}

model SupportReply {
  id          Int            @id @default(autoincrement())
  ticketId    Int
  senderId    Int
  message     String         @db.Text
  isAdmin     Boolean        @default(false)
  
  createdAt   DateTime       @default(now())

  ticket      SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Blog {
  id              Int      @id @default(autoincrement())
  title           String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  content         String   @db.LongText
  excerpt         String?  @db.Text
  author          String   @default("Admin")
  category        String?  @default("Travel")
  tags            String?  @db.Text
  
  featuredImage   String?  @db.Text
  imageAltText    String?  @db.VarChar(255)
  imageTitle      String?  @db.VarChar(255)
  imageCaption    String?  @db.Text

  // SEO Fields
  metaTitle       String?  @db.VarChar(255)
  metaDescription String?  @db.Text
  focusKeyword    String?  @db.VarChar(255)
  canonicalUrl    String?  @db.Text
  robots          String?  @default("index, follow")
  
  // OG Fields
  ogTitle         String?  @db.VarChar(255)
  ogDescription   String?  @db.Text
  ogImage         String?  @db.Text

  // Structure & Schema
  faqSchema       Json?    
  
  // Analytics & Engagement
  viewsCount      Int      @default(0)
  readTime        Int?     
  likes           Int      @default(0)
  shares          Int      @default(0)
  commentsEnabled Boolean  @default(true)

  isActive        Boolean  @default(true)
  publishDate     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([slug])
  @@index([category])
}
